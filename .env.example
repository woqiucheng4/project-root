# 复制为 .env 或在各应用目录配置
# Monorepo 根目录（agents 写 docs/ 时使用；从 apps/web 启动时务必设置）
MONOREPO_ROOT=

# PostgreSQL（与 docker-compose.workflow.yml 默认一致）
DATABASE_URL="postgresql://dev:dev@localhost:5432/autonomous_loop"

# Redis（BullMQ）
REDIS_HOST=localhost
REDIS_PORT=6379

# LLM（ai-agents）
OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=gpt-4o
# OFFLINE_MODE=true
# LOCAL_OPENAI_BASE_URL=http://localhost:11434/v1
# LOCAL_OPENAI_MODEL=qwen:7b

# ai-runtime 可选：注入旧版直 DEV 演示任务
# RUN_LEGACY_DEV_SEED=1
