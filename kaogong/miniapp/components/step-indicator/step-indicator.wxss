.steps { display: flex; justify-content: space-between; position: relative; margin-bottom: 32rpx; }
.step-line-bg { position: absolute; top: 28rpx; left: 0; right: 0; height: 4rpx; background: rgba(255,255,255,0.08); z-index: 0; }
.step-line { position: absolute; top: 28rpx; left: 0; height: 4rpx; background: #3b82f6; z-index: 1; transition: width 0.4s; }
.step-item { display: flex; flex-direction: column; align-items: center; z-index: 2; }
.step-circle { width: 56rpx; height: 56rpx; border-radius: 50%; background: #1f2937; border: 4rpx solid rgba(255,255,255,0.08); display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 28rpx; color: #9ca3af; }
.step-circle.active { background: #3b82f6; border-color: #3b82f6; color: #fff; box-shadow: 0 0 16rpx rgba(59,130,246,0.5); }
.step-label { font-size: 22rpx; color: #9ca3af; margin-top: 12rpx; }
.step-label.active { color: #e5e7eb; }
