.field { margin-bottom: 32rpx; }
.field-label { font-size: 28rpx; font-weight: 500; display: block; margin-bottom: 12rpx; }
.required { color: #ef4444; }
.field-input { width: 100%; padding: 20rpx 24rpx; border-radius: 12rpx; border: 2rpx solid rgba(255,255,255,0.08); background: rgba(0,0,0,0.2); color: #e5e7eb; font-size: 28rpx; box-sizing: border-box; }
.field-input.has-error { border-color: #ef4444; }
.picker-display { min-height: 80rpx; line-height: 40rpx; }
.radio-group { display: flex; gap: 24rpx; flex-wrap: wrap; }
.radio-item { display: flex; align-items: center; gap: 12rpx; padding: 16rpx 24rpx; border-radius: 12rpx; border: 2rpx solid rgba(255,255,255,0.08); background: rgba(0,0,0,0.2); font-size: 28rpx; color: #9ca3af; }
.radio-item.selected { border-color: #3b82f6; color: #e5e7eb; }
.radio-dot { width: 32rpx; height: 32rpx; border-radius: 50%; border: 4rpx solid rgba(255,255,255,0.15); }
.radio-dot.active { border-color: #3b82f6; background: #3b82f6; box-shadow: 0 0 12rpx rgba(59,130,246,0.5); }
.field-error { font-size: 24rpx; color: #ef4444; margin-top: 8rpx; display: block; }
