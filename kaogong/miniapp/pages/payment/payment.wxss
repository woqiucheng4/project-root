.pay-card { margin-top: 80rpx; text-align: center; }
.pay-title { font-size: 40rpx; font-weight: bold; display: block; margin-bottom: 48rpx; }
.order-box { background: rgba(0,0,0,0.2); padding: 40rpx; border-radius: 16rpx; margin-bottom: 48rpx; }
.order-desc { font-size: 28rpx; color: #9ca3af; display: block; margin-bottom: 16rpx; }
.order-price { font-size: 72rpx; font-weight: bold; display: block; background: linear-gradient(135deg, #10b981, #3b82f6); -webkit-background-clip: text; color: transparent; }
.order-id { font-size: 22rpx; color: #9ca3af; display: block; margin-top: 24rpx; word-break: break-all; opacity: 0.6; }
.btn-pay-main { width: 100% !important; padding: 28rpx 0; font-size: 34rpx; font-weight: bold; border: none; background: #10b981 !important; color: #fff !important; border-radius: 999rpx; box-shadow: 0 8rpx 24rpx rgba(16,185,129,0.4); }
.pay-note { font-size: 24rpx; color: #9ca3af; display: block; margin-top: 40rpx; line-height: 1.6; opacity: 0.8; }
