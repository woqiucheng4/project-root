# Default Primary OpenAI settings for cloud models
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# ------------------------------------------------------------------------
# Local LLM Fallback Support (Ollama, LM Studio, vLLM, DeepSeek, Qwen)
# ------------------------------------------------------------------------

# Fallback Settings: Auto-used if the primary cloud model fails or times out.
# LOCAL_OPENAI_BASE_URL=http://localhost:11434/v1
# LOCAL_OPENAI_MODEL=qwen:7b   # or deepseek-coder:6.7b
# LOCAL_OPENAI_API_KEY=sk-local # (Optional)

# Set to 'true' to always skip the cloud connection attempt and use local models.
# OFFLINE_MODE=true
